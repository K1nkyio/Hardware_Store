{
  "name": "hardware-store-backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "db:migrate": "node --import tsx src/db/migrate.ts",
    "lint": "eslint .",
    "backup:db": "node scripts/backup-db.mjs"
