    "pg": "^8.12.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.16.5",
    "@types/pg": "^8.11.10",
    "eslint": "^9.32.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
